# Configuración de Supabase
# Obtén estos valores desde tu proyecto en https://supabase.com/dashboard

# URL de tu proyecto de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública de Supabase (es seguro exponerla en el cliente)
VITE_SUPABASE_ANON_KEY=tu-clave-anon-key-aqui

# Instrucciones:
# 1. Copia este archivo y renómbralo a .env
# 2. Reemplaza los valores de ejemplo con tus credenciales reales de Supabase
# 3. Nunca compartas tu archivo .env ni lo subas a Git
# 4. El archivo .env ya está en .gitignore para tu seguridad
